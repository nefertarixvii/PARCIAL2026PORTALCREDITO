@model List<PlataformaCreditos.Models.SolicitudCredito>

<h2>Mis Solicitudes</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<a asp-action="Crear" class="btn btn-primary">Nueva Solicitud</a>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Monto</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.MontoSolicitado</td>
                <td>@item.FechaSolicitud.ToShortDateString()</td>
                <td>@item.Estado</td>
                <td>
                    <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver</a>
                </td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="4">No tienes solicitudes registradas</td>
        </tr>
    }
    </tbody>
</table>